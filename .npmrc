# Route all @comprodls packages to GitHub Packages.
# Set NPM_TOKEN (or GITHUB_TOKEN) in your shell / CI environment before running pnpm install.
#
# Example (local shell):
#   export NPM_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
#
# Example (GitHub Actions):
#   uses: actions/setup-node@v4
#   with:
#     registry-url: https://npm.pkg.github.com
#     scope: '@comprodls'
#   env:
#     NODE_AUTH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
@comprodls:registry=https://npm.pkg.github.com
# Uncomment and set your token for cloud installs (GitHub Actions sets NODE_AUTH_TOKEN automatically):
//npm.pkg.github.com/:_authToken=${NPM_TOKEN}
